                      "fontSize": 12,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "yZtFL",
                      "name": "Code Content",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": 550,
                      "content": "curl https://api.ruteai.com/v1/chat/completions \\\n  -H \"Authorization: Bearer rute_KEY\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\\\n    \"model\": \"gpt-4o\",\\\n    \"messages\": [\\\n      {\"role\": \"user\", \"content\": \"Hello!\"}\\\n    ]\\\n  }'",
                      "fontFamily": "Manrope",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "OWBq6",
                      "name": "JS Label",
                      "fill": "$text-tertiary",
                      "content": "JavaScript/Node.js Example",
                      "fontFamily": "Manrope",
                      "fontSize": 12,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "Lyb6X",
                      "name": "JS Content",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": 550,
                      "content": "const response = await fetch(\n  'https://api.ruteai.com/v1/chat/completions', {\n  method: 'POST',\n  headers: {\n    'Authorization': 'Bearer rute_KEY',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    model: 'gpt-4o',\n    messages: [{\n      role: 'user',\n      content: 'Hello!'\n    }]\n  })\n});\n\nconst data = await response.json();\nconsole.log(data.choices[0].message.content);",
                      "fontFamily": "Manrope",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
