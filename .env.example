# Convex deployment (set by `npx convex dev`)
CONVEX_DEPLOYMENT=dev:adjective-animal-123
VITE_CONVEX_URL=https://adjective-animal-123.convex.cloud
VITE_CONVEX_SITE_URL=https://adjective-animal-123.convex.site

# Site URL
VITE_SITE_URL=http://localhost:3000

# Better Auth (set via `npx convex env set`)
# BETTER_AUTH_SECRET=<generate with `openssl rand -base64 32` or `npx auth secret`>
# SITE_URL=http://localhost:3000

# Google OAuth (set via `npx convex env set`)
# GOOGLE_CLIENT_ID=<from Google Cloud Console>
# GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

# Mayar (set via `npx convex env set`)
# MAYAR_API_KEY=<your Mayar API key>
# MAYAR_API_BASE_URL=https://api.mayar.id
# MAYAR_PRODUCT_ID=<your credit-based membership product ID>
# MAYAR_MEMBERSHIP_TIER_ID=<your membership tier ID>
